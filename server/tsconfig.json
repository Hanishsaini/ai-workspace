{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@workspace/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../packages/shared/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
