# ════════════════════════════════════════════════════════════════════════
#  AI Workspace — environment template
#
#  Zero-Docker local setup using fully free hosted services:
#    - Supabase free tier (Postgres)
#    - Upstash  free tier (Redis)
#    - Groq    free tier (AI) — or Gemini, or built-in mock mode
#
#  Copy this file to `.env.local` and fill in the four bracketed values
#  (Supabase × 2, Upstash × 1, AI key). The rest carries safe dev defaults.
# ════════════════════════════════════════════════════════════════════════

# ─── Database (Supabase) ────────────────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string
#   DATABASE_URL → "Transaction" pooler URL (port 6543) — used by app code
#   DIRECT_URL   → "Direct"/"Session" URL    (port 5432) — used by migrations
# Append `?pgbouncer=true&connection_limit=1` to DATABASE_URL (required for
# Prisma + pgBouncer transaction mode).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Redis (Upstash) ────────────────────────────────────────────────────
# Upstash Console → your database → "Redis CLI" tab → copy the rediss:// URL.
# Must be the TCP/TLS endpoint — the REST URL (https://) will NOT work
# because we use socket.io pub/sub and ioredis, not HTTP commands.
REDIS_URL="rediss://default:PASSWORD@your-db.upstash.io:6379"

# ─── AI providers — ALL OPTIONAL ────────────────────────────────────────
# AI_PROVIDER: auto | groq | gemini | openai | mock
#   auto → first provider with a key wins (groq → gemini → openai),
#          falls back to mock when no key is set at all.
AI_PROVIDER="auto"

# Groq (recommended free tier) — https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Gemini (free fallback) — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# OpenAI (optional, paid) — drop-in via the same abstraction
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ─── Auth (NextAuth) — dev defaults baked in; override for prod ─────────
# Generate a strong secret with:  openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-only-insecure-secret-change-me"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — https://github.com/settings/developers (New OAuth App)
# Authorized callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# Dev-only email-lookup login (no password). Defaults: ENABLED in dev,
# DISABLED in production. Set "false" to force off, "true" to force on.
ENABLE_DEV_LOGIN=""

# Seed flags — pnpm db:seed is a no-op unless these are set.
#   SEED_DEV_USERS=true   → creates alice@example.com + bob@example.com
#                           each with their own personal workspace
#   SEED_DEMO_SHARED=true → additionally creates a shared "Demo Workspace"
#                           with both seeded users for collab testing
SEED_DEV_USERS=""
SEED_DEMO_SHARED=""

# ─── Realtime — must match the socket server's secrets ─────────────────
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
SOCKET_SERVER_URL="http://localhost:4000"
REALTIME_TOKEN_SECRET="dev-only-realtime-secret-change!"
SERVICE_TOKEN="dev-only-service-token-change!!!"
